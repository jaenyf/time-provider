{
  "name": "time-provider",
  "version": "0.0.4",
  "private": true,
  "description": "A TypeScript library for injecting time into your application, making time-dependent code deterministic, easy to test, and independent of your date library.",
  "keywords": [
    "clock",
    "date",
    "deterministic",
    "fake",
    "fixed",
    "frozen",
    "injection",
    "manual",
    "provider",
    "running",
    "system",
    "time"
  ],
  "homepage": "https://github.com/jaenyf/time-provider#readme",
  "bugs": {
    "url": "https://github.com/jaenyf/time-provider/issues"
  },
  "license": "MIT",
  "author": "jaenyf",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaenyf/time-provider.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "ready": "vp run test && vp run build && vp run check && vp run stryker",
    "dev": "vp run website#dev",
    "prepare": "vp config",
    "build": "vp run -r build",
    "publish": "vp run -r publish",
    "clean": "rimraf -g node_modules packages/**/dist/** packages/**/node_modules/** .stryker-tmp coverage reports bun.lock",
    "test": "vp test",
    "check": "vp run -r check",
    "stryker": "stryker run"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "4.1.10",
    "rimraf": "^6.1.3",
    "vite-plus": "^0.2.2"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "vite-plus": "latest"
  }
}
