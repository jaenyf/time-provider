{
  "name": "time-provider",
  "version": "0.0.1",
  "private": true,
  "description": "A tiny library to rapidly have time!",
  "keywords": [
    "date",
    "fake",
    "fixed",
    "provider",
    "running",
    "time"
  ],
  "homepage": "https://github.com/jaenyf/time-provider#readme",
  "bugs": {
    "url": "https://github.com/jaenyf/time-provider/issues"
  },
  "license": "MIT",
  "author": "jaenyf",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaenyf/time-provider.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "ready": "vp run test && vp run build && vp run check && vp run stryker",
    "dev": "vp run website#dev",
    "prepare": "vp config",
    "build": "vp run -r build",
    "test": "vp test",
    "check": "vp run -r check",
    "stryker": "stryker run"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.9",
    "vite-plus": "^0.2.1"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vite-plus": "latest"
  }
}
