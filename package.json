{
  "name": "time-provider",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "ready": "vp run test && vp run build && vp run check && vp run stryker",
    "dev": "vp run website#dev",
    "prepare": "vp config",
    "build": "vp run -r build",
    "clean": "rimraf -g node_modules packages/**/dist/** packages/**/node_modules/** .stryker-tmp coverage reports bun.lock",
    "test": "vp test",
    "check": "vp run -r check",
    "stryker": "stryker run"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.2.0",
    "@js-temporal/polyfill": "~0.5.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "4.1.10",
    "rimraf": "^6.1.3",
    "typescript": "catalog:",
    "validate-branch-name": "^1.3.2",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "vite-plus": "latest",
    "vitest": "latest",
    "typescript": "^6.0.3",
    "@types/node": "25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2"
  },
  "validate-branch-name": {
    "pattern": "^(main)$|^(ai|bugfix|chore|ci|docs|feat|feature|fix|hotfix|perf|release|refactor)/.+$",
    "errorMsg": "Branch name must be main, or <type>/<description> (ai, bugfix, chore, ci, docs, feat, feature, fix, hotfix, perf, release, refactor) - see conventionalbranch.org"
  }
}
