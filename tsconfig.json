{
  "compilerOptions": {
    "noEmit": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "paths": {
      "@time-provider/*/deterministic": ["./packages/*/src/deterministic"],
      "@time-provider/*": ["./packages/*/src"]
    }
  }
}
