{
  "name": "@time-provider/plugin-temporal",
  "version": "0.0.4",
  "private": false,
  "description": "Time-Provider : Temporal plugin ~ A TypeScript library for injecting time into your application, making time-dependent code deterministic, easy to test, and independent of your date library.",
  "keywords": [
    "clock",
    "date",
    "deterministic",
    "fake",
    "fixed",
    "frozen",
    "injection",
    "manual",
    "provider",
    "running",
    "system",
    "time"
  ],
  "homepage": "https://github.com/jaenyf/time-provider#readme",
  "bugs": {
    "url": "https://github.com/jaenyf/time-provider/issues"
  },
  "license": "MIT",
  "author": "jaenyf",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaenyf/time-provider.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "publish": "vpx npm publish"
  },
  "devDependencies": {
    "@time-provider/core": "workspace:*",
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@js-temporal/polyfill": "~0.5.1",
    "@time-provider/core": "^0.0.0"
  }
