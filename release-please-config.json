{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "changelog-path": "CHANGELOG.md",
  "separate-pull-requests": false,
  "include-component-in-tag": true,
  "group-pull-request-title-pattern": "chore: next release",
  "packages": {
    "packages/core": {
      "release-type": "node",
      "component": "core",
      "versioning": "always-bump-minor"
    },
    "packages/plugin-dayjs": {
      "release-type": "node",
      "component": "plugin-dayjs",
      "versioning": "always-bump-minor"
    },
    "packages/plugin-luxon": {
      "release-type": "node",
      "component": "plugin-luxon",
      "versioning": "always-bump-minor"
    },
    "packages/plugin-moment": {
      "release-type": "node",
      "component": "plugin-moment",
      "versioning": "always-bump-minor"
    },
    "packages/plugin-native": {
      "release-type": "node",
      "component": "plugin-native",
      "versioning": "always-bump-minor"
    },
    "packages/plugin-temporal": {
      "release-type": "node",
      "component": "plugin-temporal",
      "versioning": "always-bump-minor"
    }
  }
}
